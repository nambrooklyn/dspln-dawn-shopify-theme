{%- comment -%}
  DSPLN account tab bar, shared by the dashboard, order and addresses pages.

  Accepts:
  - active: 'overview' | 'orders' | 'designs' | 'addresses'

  On the dashboard the overview/orders/designs tabs switch client-side
  panels (script in main-account.liquid); everywhere else they are plain
  links back to /account with the matching hash.
{%- endcomment -%}

<nav class="dspln-account-nav" aria-label="{{ 'customer.account.title' | t }}">
  <a
    class="dspln-account-nav__tab{% if active == 'overview' %} dspln-account-nav__tab--active{% endif %}"
    href="{{ routes.account_url }}#overview"
    data-account-tab="overview"
    {% if active == 'overview' %}aria-current="page"{% endif %}
  >
    Overview
  </a>
  <a
    class="dspln-account-nav__tab{% if active == 'orders' %} dspln-account-nav__tab--active{% endif %}"
    href="{{ routes.account_url }}#orders"
    data-account-tab="orders"
    {% if active == 'orders' %}aria-current="page"{% endif %}
  >
    {{ 'customer.orders.title' | t }}
  </a>
  <a
    class="dspln-account-nav__tab{% if active == 'designs' %} dspln-account-nav__tab--active{% endif %}"
    href="{{ routes.account_url }}#designs"
    data-account-tab="designs"
    {% if active == 'designs' %}aria-current="page"{% endif %}
  >
    My Designs
  </a>
  <a
    class="dspln-account-nav__tab{% if active == 'addresses' %} dspln-account-nav__tab--active{% endif %}"
    href="{{ routes.account_addresses_url }}"
    {% if active == 'addresses' %}aria-current="page"{% endif %}
  >
    {{ 'customer.addresses.title' | t }}
  </a>
</nav>
