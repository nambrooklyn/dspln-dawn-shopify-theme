{%- comment -%}
  DSPLN account icon rail — the slim black bar on the far left of the
  account shell. Store-level shortcuts; the horizontal tabs handle
  account-level navigation.
{%- endcomment -%}

<nav class="dspln-account-rail" aria-label="{{ shop.name }}">
  <a class="dspln-account-rail__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">D</a>

  <a class="dspln-account-rail__item" href="{{ routes.root_url }}">
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M3 9.5 10 3l7 6.5M5 8.5V17h10V8.5"/>
    </svg>
    <span>Home</span>
  </a>

  <a class="dspln-account-rail__item" href="{{ routes.all_products_collection_url }}">
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M4 6h12l-1 11H5L4 6ZM7 6a3 3 0 0 1 6 0"/>
    </svg>
    <span>Shop</span>
  </a>

  <a class="dspln-account-rail__item dspln-account-rail__item--active" href="{{ routes.account_url }}" aria-current="page">
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <circle cx="10" cy="6.5" r="3"/>
      <path d="M4 17c.8-3.2 3.1-4.8 6-4.8s5.2 1.6 6 4.8"/>
    </svg>
    <span>Account</span>
  </a>

  <a class="dspln-account-rail__item dspln-account-rail__item--logout" href="{{ routes.account_logout_url }}">
    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M12 4H5v12h7M9 10h8m0 0-3-3m3 3-3 3"/>
    </svg>
    <span>Log out</span>
  </a>
</nav>
