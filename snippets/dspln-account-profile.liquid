{%- comment -%}
  DSPLN account profile panel, shared by the dashboard, order and
  addresses pages. Monogram, identity, default address and log-out.
{%- endcomment -%}

<aside class="dspln-account-profile" aria-label="{{ 'customer.account.details' | t }}">
  <div class="dspln-account-profile__monogram" aria-hidden="true">
    {{- customer.first_name | slice: 0 -}}
    {{- customer.last_name | slice: 0 -}}
  </div>

  <p class="dspln-account-profile__name">{{ customer.name }}</p>
  <p class="dspln-account-profile__email">{{ customer.email }}</p>

  {%- if customer.default_address != blank -%}
    <p class="dspln-account-profile__kicker">{{ 'customer.addresses.default' | t }}</p>
    {{ customer.default_address | format_address }}
  {%- endif -%}
</aside>
