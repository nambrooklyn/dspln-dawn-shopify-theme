{{ 'dspln-kids-gi-feature.css' | asset_url | stylesheet_tag }}

<section class="dspln-kids-gi-feature" aria-label="Kids custom gi">
  <div class="dspln-kids-gi-feature__inner">
    <div class="dspln-kids-gi-feature__media">
      <img
        src="{{ 'dspln-kids-gi-front.webp' | asset_url }}"
        alt="Kids custom Brazilian Jiu Jitsu gi"
        width="900"
        height="900"
        loading="lazy"
      >
    </div>

    <div class="dspln-kids-gi-feature__copy">
      <h2 class="dspln-kids-gi-feature__heading">{{ section.settings.heading }}</h2>
      <p class="dspln-kids-gi-feature__text">{{ section.settings.text }}</p>

      <div class="dspln-kids-gi-feature__points">
        <div class="dspln-kids-gi-feature__point">
          <img
            class="dspln-kids-gi-feature__icon"
            src="{{ 'dspln-icon-color.png' | asset_url }}"
            alt=""
            width="24"
            height="24"
            loading="lazy"
          >
          <span>{{ section.settings.point_one }}</span>
        </div>
        <div class="dspln-kids-gi-feature__point">
          <img
            class="dspln-kids-gi-feature__icon"
            src="{{ 'dspln-icon-art.png' | asset_url }}"
            alt=""
            width="24"
            height="24"
            loading="lazy"
          >
          <span>{{ section.settings.point_two }}</span>
        </div>
        <div class="dspln-kids-gi-feature__point">
          <img
            class="dspln-kids-gi-feature__icon"
            src="{{ 'dspln-icon-size.png' | asset_url }}"
            alt=""
            width="30"
            height="30"
            loading="lazy"
          >
          <span>{{ section.settings.point_three }}</span>
        </div>
      </div>

      <div class="dspln-kids-gi-feature__actions">
        <a href="{{ section.settings.primary_link }}" class="dspln-kids-gi-feature__button dspln-kids-gi-feature__button--primary">
          {{ section.settings.primary_label }}
        </a>
        <a href="{{ section.settings.secondary_link }}" class="dspln-kids-gi-feature__button dspln-kids-gi-feature__button--secondary">
          {{ section.settings.secondary_label }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DSPLN kids gi feature",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "KIDS CUSTOM GI"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "With a range of customizable features, kids can let their creativity shine as they design their perfect training gear. Whether it's selecting colors for each part, adding unique patches, or customizing embroidery, every detail can mirror their individual style and love for the sport. Imagine the excitement of stepping onto the mat in a gi that they've played a part in creating—it's sure to ignite their passion for training!"
    },
    {
      "type": "text",
      "id": "point_one",
      "label": "Point one",
      "default": "Change color of every component including stitching."
    },
    {
      "type": "text",
      "id": "point_two",
      "label": "Point two",
      "default": "Add up to 8 logos and art. Add text to your belt"
    },
    {
      "type": "text",
      "id": "point_three",
      "label": "Point three",
      "default": "Any sizes for the kimono, belt, and pants, ensuring a perfect fit."
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "START DESIGNING"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "SEE THE PROCESS"
    }
  ],
  "presets": [
    {
      "name": "DSPLN kids gi feature"
    }
  ]
}
{% endschema %}
