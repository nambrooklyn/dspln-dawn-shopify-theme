{{ 'dspln-contact-page.css' | asset_url | stylesheet_tag }}

<section class="dspln-contact" aria-label="Contact DSPLN">
  {% if section.settings.background_image != blank %}
    <img class="dspln-contact__image" src="{{ section.settings.background_image | image_url: width: 2400 }}" alt="" width="{{ section.settings.background_image.width }}" height="{{ section.settings.background_image.height }}" loading="lazy">
  {% else %}
    <img class="dspln-contact__image" src="{{ 'dspln-contact-bg.png' | asset_url }}" alt="" width="1920" height="686" loading="lazy">
  {% endif %}
  <div class="dspln-contact__inner">
    <div class="dspln-contact__panel">
      {% if section.settings.heading != blank %}
        <h1 class="dspln-contact__heading">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="dspln-contact__intro">{{ section.settings.text }}</div>
      {% endif %}

      {% form 'contact', id: 'DSPLNContactForm', class: 'dspln-contact__form' %}
        {% if form.posted_successfully? %}
          <p class="dspln-contact__status" tabindex="-1" autofocus>Thanks for contacting us. We'll get back to you as soon as possible.</p>
        {% endif %}

        {% if form.errors %}
          <ul class="dspln-contact__errors" role="alert">
            {% for field in form.errors %}
              <li>
                {% if field == 'form' %}
                  {{ form.errors.messages[field] }}
                {% else %}
                  {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% endif %}

        <div class="dspln-contact__field-row">
          <div class="dspln-contact__field">
            <label for="DSPLNContactForm-name">Name</label>
            <input
              id="DSPLNContactForm-name"
              type="text"
              name="contact[Name]"
              autocomplete="name"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
            >
          </div>

          <div class="dspln-contact__field">
            <label for="DSPLNContactForm-email">Email *</label>
            <input
              id="DSPLNContactForm-email"
              type="email"
              name="contact[email]"
              autocomplete="email"
              autocapitalize="off"
              spellcheck="false"
              required
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
              {% endif %}
            >
          </div>
        </div>

        <div class="dspln-contact__field">
          <label for="DSPLNContactForm-body">Message</label>
          <textarea id="DSPLNContactForm-body" name="contact[Message]" rows="6">{{ form.body }}</textarea>
        </div>

        <div class="dspln-contact__button-wrap">
          <button class="dspln-contact__button" type="submit">{{ section.settings.button_label }}</button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DSPLN contact",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Have Any Questions?"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Have a question or need assistance? Drop us a message, we're here to help!</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Send message"
    }
  ],
  "presets": [
    {
      "name": "DSPLN contact"
    }
  ]
}
{% endschema %}
