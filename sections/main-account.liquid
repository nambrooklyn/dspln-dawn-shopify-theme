{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'dspln-account.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="customer account dspln-account dspln-account--dashboard section-{{ section.id }}-padding">
  <div class="dspln-account__header">
    <h1 class="customer__title">{{ 'customer.account.title' | t }}</h1>
    {%- if customer.first_name != blank and section.settings.welcome_text != blank -%}
      <p class="dspln-account__welcome">{{ section.settings.welcome_text }}, {{ customer.first_name }}</p>
    {%- endif -%}
  </div>

  <div class="dspln-account__layout">
    {% render 'dspln-account-rail' %}
    {% render 'dspln-account-profile' %}

    <div class="dspln-account__content">
      {% render 'dspln-account-nav', active: 'overview' %}

      <div class="dspln-account__tab-panel" data-account-panel="overview" id="overview-panel">
        <div class="dspln-account__stats">
          <div class="dspln-account__stat">
            <span class="dspln-account__stat-value">{{ customer.orders_count }}</span>
            <span class="dspln-account__stat-label">{{ 'customer.orders.title' | t }}</span>
          </div>
          <div class="dspln-account__stat">
            <span class="dspln-account__stat-value">{{ customer.total_spent | money }}</span>
            <span class="dspln-account__stat-label">Total spent</span>
          </div>
          <div class="dspln-account__stat">
            <span class="dspln-account__stat-value">{{ customer.addresses_count }}</span>
            <span class="dspln-account__stat-label">{{ 'customer.addresses.title' | t }}</span>
          </div>
        </div>

        <h2>Recent orders</h2>
        {%- if customer.orders.size > 0 -%}
          <ul class="dspln-account__recent" role="list">
            {%- for order in customer.orders limit: 3 -%}
              <li class="dspln-account__recent-row">
                <a href="{{ order.customer_url }}" class="dspln-account__recent-name">{{ order.name }}</a>
                <span class="dspln-account__recent-date">{{ order.created_at | time_tag: format: 'date' }}</span>
                <span class="dspln-account__status{% if order.fulfillment_status == 'fulfilled' %} dspln-account__status--good{% endif %}">
                  {{- order.fulfillment_status_label -}}
                </span>
                <span class="dspln-account__recent-total">{{ order.total_net_amount | money_with_currency }}</span>
              </li>
            {%- endfor -%}
          </ul>
          <a class="dspln-account__text-link" href="{{ routes.account_url }}#orders" data-account-tab="orders">
            View all orders
          </a>
        {%- else -%}
          <div class="dspln-account__empty">
            <p>{{ 'customer.orders.none' | t }}</p>
            {%- if section.settings.shop_button_label != blank -%}
              <a
                class="dspln-account__button"
                href="{{ section.settings.shop_link | default: routes.all_products_collection_url }}"
              >
                {{ section.settings.shop_button_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      <div class="dspln-account__tab-panel" data-account-panel="orders" id="orders-panel" hidden>
      <h2>{{ 'customer.orders.title' | t }}</h2>

      {% paginate customer.orders by 20 %}
        {%- if customer.orders.size > 0 -%}
          <table role="table" class="order-history">
            <caption class="visually-hidden">
              {{ 'customer.orders.title' | t }}
            </caption>
            <thead role="rowgroup">
              <tr role="row">
                <th id="ColumnOrder" scope="col" role="columnheader">{{ 'customer.orders.order_number' | t }}</th>
                <th id="ColumnDate" scope="col" role="columnheader">{{ 'customer.orders.date' | t }}</th>
                <th id="ColumnPayment" scope="col" role="columnheader">{{ 'customer.orders.payment_status' | t }}</th>
                <th id="ColumnFulfillment" scope="col" role="columnheader">
                  {{ 'customer.orders.fulfillment_status' | t }}
                </th>
                <th id="ColumnTotal" scope="col" role="columnheader">{{ 'customer.orders.total' | t }}</th>
              </tr>
            </thead>
            <tbody role="rowgroup">
              {%- for order in customer.orders -%}
                <tr role="row">
                  <td
                    id="RowOrder"
                    role="cell"
                    headers="ColumnOrder"
                    data-label="{{ 'customer.orders.order_number' | t }}"
                  >
                    <a
                      href="{{ order.customer_url }}"
                      aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}"
                    >
                      {{ order.name }}
                    </a>
                  </td>
                  <td headers="RowOrder ColumnDate" role="cell" data-label="{{ 'customer.orders.date' | t }}">
                    {{ order.created_at | time_tag: format: 'date' }}
                  </td>
                  <td
                    headers="RowOrder ColumnPayment"
                    role="cell"
                    data-label="{{ 'customer.orders.payment_status' | t }}"
                  >
                    <span class="dspln-account__status{% if order.financial_status == 'paid' %} dspln-account__status--good{% elsif order.financial_status == 'refunded' or order.financial_status == 'voided' %} dspln-account__status--alert{% endif %}">
                      {{- order.financial_status_label -}}
                    </span>
                  </td>
                  <td
                    headers="RowOrder ColumnFulfillment"
                    role="cell"
                    data-label="{{ 'customer.orders.fulfillment_status' | t }}"
                  >
                    <span class="dspln-account__status{% if order.fulfillment_status == 'fulfilled' %} dspln-account__status--good{% endif %}">
                      {{- order.fulfillment_status_label -}}
                    </span>
                  </td>
                  <td headers="RowOrder ColumnTotal" role="cell" data-label="{{ 'customer.orders.total' | t }}">
                    {{ order.total_net_amount | money_with_currency }}
                  </td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        {%- else -%}
          <div class="dspln-account__empty">
            <p>{{ 'customer.orders.none' | t }}</p>
            {%- if section.settings.shop_button_label != blank -%}
              <a
                class="dspln-account__button"
                href="{{ section.settings.shop_link | default: routes.all_products_collection_url }}"
              >
                {{ section.settings.shop_button_label }}
              </a>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if paginate.pages > 1 -%}
          {%- if paginate.parts.size > 0 -%}
            <nav class="pagination" role="navigation" aria-label="{{ 'general.pagination.label' | t }}">
              <ul role="list">
                {%- if paginate.previous -%}
                  <li>
                    <a href="{{ paginate.previous.url }}" aria-label="{{ 'general.pagination.previous' | t }}">
                      <span class="svg-wrapper">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </a>
                  </li>
                {%- endif -%}

                {%- for part in paginate.parts -%}
                  <li>
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                        {{- part.title -}}
                      </a>
                    {%- else -%}
                      {%- if part.title == paginate.current_page -%}
                        <span aria-current="page" aria-label="{{ 'general.pagination.page' | t: number: part.title }}">
                          {{- part.title -}}
                        </span>
                      {%- else -%}
                        <span>{{ part.title }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  </li>
                {%- endfor -%}

                {%- if paginate.next -%}
                  <li>
                    <a href="{{ paginate.next.url }}" aria-label="{{ 'general.pagination.next' | t }}">
                      <span class="svg-wrapper">
                        {{- 'icon-caret.svg' | inline_asset_content -}}
                      </span>
                    </a>
                  </li>
                {%- endif -%}
              </ul>
            </nav>
          {%- endif -%}
        {%- endif -%}
      {% endpaginate %}
      </div>

      {%- if section.settings.show_designs -%}
        <div class="dspln-account__tab-panel" data-account-panel="designs" id="designs-panel" hidden>
          <div class="dspln-account__designs">
            <h2>{{ section.settings.designs_heading }}</h2>
            <div class="dspln-account__empty">
              {%- if section.settings.designs_text != blank -%}
                <p>{{ section.settings.designs_text }}</p>
              {%- endif -%}
              {%- if section.settings.designs_button_label != blank -%}
                <a
                  class="dspln-account__button dspln-account__button--secondary"
                  href="{{ section.settings.designs_link | default: routes.all_products_collection_url }}"
                >
                  {{ section.settings.designs_button_label }}
                </a>
              {%- endif -%}
            </div>
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function () {
    var tabs = Array.prototype.slice.call(document.querySelectorAll('[data-account-tab]'));
    var panels = Array.prototype.slice.call(document.querySelectorAll('[data-account-panel]'));
    if (!panels.length) return;

    function show(name) {
      var match = panels.some(function (p) {
        return p.getAttribute('data-account-panel') === name;
      });
      if (!match) name = 'overview';
      panels.forEach(function (p) {
        p.hidden = p.getAttribute('data-account-panel') !== name;
      });
      tabs.forEach(function (t) {
        var active = t.getAttribute('data-account-tab') === name && t.classList.contains('dspln-account-nav__tab');
        t.classList.toggle('dspln-account-nav__tab--active', active);
        if (t.classList.contains('dspln-account-nav__tab')) {
          if (active) t.setAttribute('aria-current', 'page');
          else t.removeAttribute('aria-current');
        }
      });
    }

    function fromLocation() {
      var name = window.location.hash.replace('#', '');
      if (!name && /[?&]page=/.test(window.location.search)) name = 'orders';
      show(name || 'overview');
    }

    tabs.forEach(function (t) {
      t.addEventListener('click', function (event) {
        var name = t.getAttribute('data-account-tab');
        event.preventDefault();
        if (window.history.replaceState) window.history.replaceState(null, '', '#' + name);
        show(name);
        window.scrollTo({ top: 0, behavior: 'auto' });
      });
    });

    window.addEventListener('hashchange', fromLocation);
    fromLocation();
  })();
</script>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "text",
      "id": "welcome_text",
      "label": "Welcome text (before first name)",
      "default": "Welcome back"
    },
    {
      "type": "header",
      "content": "Empty order history"
    },
    {
      "type": "text",
      "id": "shop_button_label",
      "label": "Shop button label",
      "default": "Start shopping"
    },
    {
      "type": "url",
      "id": "shop_link",
      "label": "Shop button link"
    },
    {
      "type": "header",
      "content": "My Designs"
    },
    {
      "type": "checkbox",
      "id": "show_designs",
      "label": "Show My Designs block",
      "default": true
    },
    {
      "type": "text",
      "id": "designs_heading",
      "label": "Heading",
      "default": "My Designs"
    },
    {
      "type": "textarea",
      "id": "designs_text",
      "label": "Text",
      "default": "Your saved gi designs will live here. Create a custom gi in the configurator and it will follow you home."
    },
    {
      "type": "text",
      "id": "designs_button_label",
      "label": "Button label",
      "default": "Design your gi"
    },
    {
      "type": "url",
      "id": "designs_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ]
}
{% endschema %}
