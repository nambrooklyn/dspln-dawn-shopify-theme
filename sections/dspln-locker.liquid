{%- liquid
  assign locker_app_origin = 'https://dspln-dawn-shopify-theme.netlify.app'
  if shop.permanent_domain contains 'dspln-dev-2'
    assign locker_app_origin = 'https://dev--dspln-dawn-shopify-theme.netlify.app'
  endif
-%}

<style>
  .dspln-locker-page { width: 100%; max-width: 100%; min-height: 72vh; overflow-x: hidden; background: #fff; }
  .dspln-locker-signin {
    min-height: 72vh; display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 28px; padding: 48px 24px; text-align: center;
  }
  .dspln-locker-signin__mark {
    display: flex; width: 58px; height: 58px; align-items: center;
    justify-content: center; background: #1c1b1b; color: #fff; font-size: 24px;
  }
  .dspln-locker-signin h1 { margin: 0; font-size: 28px; letter-spacing: .24em; text-transform: uppercase; }
  .dspln-locker-signin p { max-width: 430px; margin: 0; color: #666; font-size: 14px; line-height: 1.7; }
  .dspln-locker-signin shopify-account {
    --shopify-account-color-accent: #1c1b1b;
    --shopify-account-color-background: #fff;
    --shopify-account-radius-base: 0;
  }
  .dspln-locker-signin__button {
    display: flex; min-width: 280px; min-height: 58px; align-items: center;
    justify-content: center; background: #1c1b1b; color: #fff;
    font-size: 13px; letter-spacing: .18em; text-transform: uppercase;
  }
  .dspln-locker-frame { display: block; width: 100%; max-width: 100vw; min-height: 880px; height: calc(100vh - 80px); border: 0; overflow: hidden; }
  @media screen and (max-width: 749px) {
    .dspln-locker-frame { min-height: 760px; height: calc(100dvh - 76px); }
  }
</style>

<section class="dspln-locker-page">
  {%- if customer -%}
    {%- capture locker_src -%}
      {{ locker_app_origin }}/locker?embedded=1&shop={{ shop.permanent_domain | url_encode }}&storefrontOrigin={{ request.origin | url_encode }}&customerId={{ customer.id | url_encode }}&customerEmail={{ customer.email | url_encode }}&firstName={{ customer.first_name | url_encode }}&lastName={{ customer.last_name | url_encode }}
    {%- endcapture -%}
    <iframe
      id="dspln-locker-frame"
      class="dspln-locker-frame"
      title="The DSPLN Locker"
      src="{{ locker_src | strip }}"
      allow="clipboard-write"
    ></iframe>
    <script>
      (() => {
        const frame = document.getElementById('dspln-locker-frame');
        if (!frame) return;
        const context = {
          type: 'dspln:locker:context',
          customerId: {{ customer.id | json }},
          orders: [
            {%- for order in customer.orders limit: 50 -%}
              {
                id: {{ order.id | json }},
                name: {{ order.name | json }},
                processedAt: {{ order.created_at | date: "%Y-%m-%dT%H:%M:%S%z" | json }},
                financialStatus: {{ order.financial_status_label | json }},
                fulfillmentStatus: {{ order.fulfillment_status_label | json }},
                totalAmount: {{ order.total_net_amount | money_without_currency | replace: ',', '' | json }},
                totalCurrency: {{ cart.currency.iso_code | default: localization.country.currency.iso_code | json }},
                statusPageUrl: {{ order.customer_url | json }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        };
        const send = () => frame.contentWindow?.postMessage(context, {{ locker_app_origin | json }});
        frame.addEventListener('load', send);
        window.addEventListener('message', (event) => {
          if (event.origin === {{ locker_app_origin | json }} && event.data?.type === 'dspln:locker:ready') send();
        });
      })();
    </script>
  {%- else -%}
    <div class="dspln-locker-signin">
      <div class="dspln-locker-signin__mark">D</div>
      <h1>The Locker</h1>
      <p>Sign in to access your saved designs, uploaded artwork, sizing profile, and Shopify orders.</p>
      <shopify-account menu="customer-account-main-menu">
        <div slot="signed-out-avatar" class="dspln-locker-signin__button">Sign in or create account</div>
      </shopify-account>
    </div>
    <script>
      document.addEventListener('storefront:signincompleted', () => window.location.reload());
    </script>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "The Locker",
  "settings": [],
  "presets": [{ "name": "The Locker" }]
}
{% endschema %}
