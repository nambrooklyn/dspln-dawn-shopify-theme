{{ 'dspln-howto-customizer.css' | asset_url | stylesheet_tag }}

<section class="dspln-howto-video" aria-label="{{ section.settings.heading | escape }}">
  <div class="dspln-howto-video__inner">
    <div class="dspln-howto-video__heading-wrap">
      <h2 class="dspln-howto-video__heading">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="dspln-howto-video__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>
    <div class="dspln-howto-video__frame" data-dspln-howto-video>
      <video
        playsinline
        preload="metadata"
        {% if section.settings.poster_image == 'phone' %}
          poster="{{ 'dspln-howto-video-phone-poster.png' | asset_url }}"
        {% else %}
          poster="{{ 'dspln-howto-video-desktop-poster.png' | asset_url }}"
        {% endif %}
      >
        {% if section.settings.video_url != blank %}
          <source src="{{ section.settings.video_url }}" type="video/mp4">
        {% endif %}
      </video>
      <button class="dspln-howto-video__play" type="button" aria-label="Play {{ section.settings.heading | escape }}">
        <span class="dspln-howto-video__play-icon"></span>
      </button>
    </div>
  </div>
</section>

<script>
  (() => {
    const section = document.currentScript.closest('.shopify-section');
    const frame = section && section.querySelector('[data-dspln-howto-video]');
    const video = frame && frame.querySelector('video');
    const button = frame && frame.querySelector('.dspln-howto-video__play');

    if (!frame || !video || !button) return;

    button.addEventListener('click', () => {
      frame.classList.add('is-playing');
      video.setAttribute('controls', 'controls');
      video.play();
    });

    video.addEventListener('pause', () => {
      if (!video.ended) return;
      frame.classList.remove('is-playing');
      video.removeAttribute('controls');
    });
  })();
</script>

{% schema %}
{
  "name": "DSPLN how-to video",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "HOW TO USE CUSTOMIZER"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "WATCH VIDEO"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "select",
      "id": "poster_image",
      "label": "Poster image",
      "default": "desktop",
      "options": [
        {
          "value": "desktop",
          "label": "Desktop customizer"
        },
        {
          "value": "phone",
          "label": "Phone customizer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DSPLN how-to video"
    }
  ]
}
{% endschema %}
