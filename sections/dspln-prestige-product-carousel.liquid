{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --dspln-carousel-gap: 2.4rem;
    --dspln-carousel-arrow-size: 4.4rem;
  }

  #shopify-section-{{ section.id }} .dspln-carousel {
    background: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .dspln-carousel__inner {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__heading {
    margin: 0 0 2.8rem;
    text-align: center;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__viewport {
    position: relative;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__track {
    display: flex;
    gap: var(--dspln-carousel-gap);
    margin: 0;
    padding: 0;
    scroll-padding-left: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__slide {
    flex: 0 0 78%;
    max-width: 78%;
    scroll-snap-align: start;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__item {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    min-height: 100%;
    text-align: center;
    text-decoration: none;
    transition: transform 180ms ease;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__item:hover {
    transform: translateY(-0.25rem);
  }

  #shopify-section-{{ section.id }} .dspln-carousel__image-frame {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    aspect-ratio: 3 / 4;
    background: #fff;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__title {
    margin: 1.6rem 0 0;
    color: rgb(var(--color-foreground));
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    font-size: 1.08rem;
    line-height: 1.25;
    text-align: center;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__item,
  #shopify-section-{{ section.id }} .dspln-carousel__item:hover,
  #shopify-section-{{ section.id }} .dspln-carousel__item:focus {
    text-decoration: none !important;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__controls {
    display: none;
  }

  #shopify-section-{{ section.id }} .dspln-carousel__view-all {
    margin-top: 2.4rem;
    text-align: center;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .dspln-carousel__inner {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__slide {
      flex-basis: calc((100% - var(--dspln-carousel-gap)) / 2);
      max-width: calc((100% - var(--dspln-carousel-gap)) / 2);
    }
  }

  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .dspln-carousel__viewport {
      padding: 0;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__track {
      overflow-x: auto;
      scroll-padding-left: 0;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__track::after {
      content: none;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__track .dspln-carousel__slide:first-child {
      margin-left: 0;
      scroll-margin-left: 0;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__slide {
      flex-basis: calc((100% - (var(--dspln-carousel-gap) * 3)) / 4);
      max-width: calc((100% - (var(--dspln-carousel-gap) * 3)) / 4);
    }

    #shopify-section-{{ section.id }} .dspln-carousel__controls {
      display: block;
      position: absolute;
      inset: 0;
      pointer-events: none;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__controls .slider-counter {
      display: none;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__controls .slider-button {
      position: absolute;
      top: 44%;
      width: var(--dspln-carousel-arrow-size);
      height: var(--dspln-carousel-arrow-size);
      border: 0.1rem solid rgba(var(--color-foreground), 0.16);
      border-radius: 50%;
      background: transparent;
      box-shadow: none;
      pointer-events: auto;
      transform: translateY(-50%);
      transition: transform 180ms ease, border-color 180ms ease;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__controls .slider-button:hover {
      border-color: rgba(var(--color-foreground), 0.28);
      transform: translateY(calc(-50% - 0.25rem));
    }

    #shopify-section-{{ section.id }} .dspln-carousel__controls .slider-button--prev {
      left: 0;
    }

    #shopify-section-{{ section.id }} .dspln-carousel__controls .slider-button--next {
      right: 0;
    }
  }
{%- endstyle -%}

{%- liquid
  assign selected_collection = section.settings.collection
  assign products_to_display = section.settings.products_to_show
  if selected_collection != blank and selected_collection.products_count < products_to_display
    assign products_to_display = selected_collection.products_count
  endif
  assign fallback_product_handles = 'customgi,womens-custom-gi-suit,custom-kids-gi,custom-long-sleeve-rashguard,custom-rashguard' | split: ','
  if selected_collection == blank
    assign products_to_display = fallback_product_handles.size
    if section.settings.products_to_show < products_to_display
      assign products_to_display = section.settings.products_to_show
    endif
  endif
-%}

<div class="dspln-carousel color-{{ section.settings.color_scheme }} gradient">
  <div class="dspln-carousel__inner page-width">
    {%- if section.settings.title != blank -%}
      <h2 class="dspln-carousel__heading {{ section.settings.heading_size }}">
        {{ section.settings.title }}
      </h2>
    {%- endif -%}

    <slider-component class="dspln-carousel__viewport slider-mobile-gutter">
      <ul
        id="Slider-{{ section.id }}"
        class="dspln-carousel__track slider slider--tablet slider--desktop"
        role="list"
        aria-label="{{ 'general.slider.name' | t }}"
      >
        {%- if selected_collection != blank and selected_collection.products.size > 0 -%}
          {%- for product in selected_collection.products limit: section.settings.products_to_show -%}
            {%- if product.tags contains 'hide' -%}
              {%- continue -%}
            {%- endif -%}
            <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="dspln-carousel__slide slider__slide">
              <a class="dspln-carousel__item" href="{{ product.url }}">
                <span class="dspln-carousel__image-frame">
                  {%- if product.featured_media -%}
                    {{
                      product.featured_media
                      | image_url: width: 900
                      | image_tag:
                        class: 'dspln-carousel__image',
                        loading: 'lazy',
                        widths: '300, 450, 600, 750, 900',
                        sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 78vw',
                        alt: product.featured_media.alt
                    }}
                  {%- else -%}
                    {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </span>
                <span class="dspln-carousel__title">{{ product.title | escape }}</span>
              </a>
            </li>
          {%- endfor -%}
        {%- elsif fallback_product_handles.size > 0 -%}
          {%- for product_handle in fallback_product_handles limit: section.settings.products_to_show -%}
            {%- assign product = all_products[product_handle] -%}
            {%- if product == blank or product.tags contains 'hide' -%}
              {%- continue -%}
            {%- endif -%}
            <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="dspln-carousel__slide slider__slide">
              <a class="dspln-carousel__item" href="{{ product.url }}">
                <span class="dspln-carousel__image-frame">
                  {%- if product.featured_media -%}
                    {{
                      product.featured_media
                      | image_url: width: 900
                      | image_tag:
                        class: 'dspln-carousel__image',
                        loading: 'lazy',
                        widths: '300, 450, 600, 750, 900',
                        sizes: '(min-width: 990px) 25vw, (min-width: 750px) 50vw, 78vw',
                        alt: product.featured_media.alt
                    }}
                  {%- else -%}
                    {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </span>
                <span class="dspln-carousel__title">{{ product.title | escape }}</span>
              </a>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="dspln-carousel__slide slider__slide">
              <div class="dspln-carousel__item">
                <span class="dspln-carousel__image-frame">
                  {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                </span>
                <span class="dspln-carousel__title">{{ 'onboarding.product_title' | t }}</span>
              </div>
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>

      {%- if products_to_display > 4 -%}
        <div class="dspln-carousel__controls slider-buttons">
          <button
            type="button"
            class="slider-button slider-button--prev"
            name="previous"
            aria-label="{{ 'general.slider.previous_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
          <div class="slider-counter caption">
            <span class="slider-counter--current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
            <span class="slider-counter--total">{{ products_to_display }}</span>
          </div>
          <button
            type="button"
            class="slider-button slider-button--next"
            name="next"
            aria-label="{{ 'general.slider.next_slide' | t }}"
            aria-controls="Slider-{{ section.id }}"
          >
            <span class="svg-wrapper">
              {{- 'icon-caret.svg' | inline_asset_content -}}
            </span>
          </button>
        </div>
      {%- endif -%}
    </slider-component>

    {%- if section.settings.show_view_all and selected_collection != blank -%}
      <div class="dspln-carousel__view-all">
        <a href="{{ selected_collection.url }}" class="button">
          {{ 'sections.featured_collection.view_all' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "DSPLN product carousel",
  "tag": "section",
  "class": "section section-dspln-product-carousel",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 12,
      "label": "Products to show"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "default": "CUSTOM BJJ GEAR",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "default": true,
      "label": "Show view all button"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "DSPLN product carousel"
    }
  ]
}
{% endschema %}
