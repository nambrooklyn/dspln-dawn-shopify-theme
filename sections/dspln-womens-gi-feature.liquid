{{ 'dspln-womens-gi-feature.css' | asset_url | stylesheet_tag }}

<section class="dspln-womens-gi-feature" aria-label="Womens custom gi">
  <div class="dspln-womens-gi-feature__inner">
    <div class="dspln-womens-gi-feature__copy">
      <h2 class="dspln-womens-gi-feature__heading">{{ section.settings.heading }}</h2>
      <p class="dspln-womens-gi-feature__text">{{ section.settings.text }}</p>

      <div class="dspln-womens-gi-feature__points">
        <div class="dspln-womens-gi-feature__point">
          <img
            class="dspln-womens-gi-feature__icon"
            src="{{ 'dspln-icon-color.png' | asset_url }}"
            alt=""
            width="24"
            height="24"
            loading="lazy"
          >
          <span>{{ section.settings.point_one }}</span>
        </div>
        <div class="dspln-womens-gi-feature__point">
          <img
            class="dspln-womens-gi-feature__icon"
            src="{{ 'dspln-icon-art.png' | asset_url }}"
            alt=""
            width="24"
            height="24"
            loading="lazy"
          >
          <span>{{ section.settings.point_two }}</span>
        </div>
        <div class="dspln-womens-gi-feature__point">
          <img
            class="dspln-womens-gi-feature__icon"
            src="{{ 'dspln-icon-size.png' | asset_url }}"
            alt=""
            width="30"
            height="30"
            loading="lazy"
          >
          <span>{{ section.settings.point_three }}</span>
        </div>
      </div>

      <div class="dspln-womens-gi-feature__actions">
        <a href="{{ section.settings.primary_link }}" class="dspln-womens-gi-feature__button dspln-womens-gi-feature__button--primary">
          {{ section.settings.primary_label }}
        </a>
        <a href="{{ section.settings.secondary_link }}" class="dspln-womens-gi-feature__button dspln-womens-gi-feature__button--secondary">
          {{ section.settings.secondary_label }}
        </a>
      </div>
    </div>

    <div class="dspln-womens-gi-feature__media">
      <img
        src="{{ 'dspln-womens-gi-front.webp' | asset_url }}"
        alt="Womens custom Brazilian Jiu Jitsu gi"
        width="400"
        height="500"
        loading="lazy"
      >
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DSPLN womens gi feature",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WOMENS CUSTOM GI"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Craft your Brazilian Jiu Jitsu gi to match your vision, offering dynamic customization options that allow you to effortlessly express your creativity. Tailored specifically for women, from selecting colors for each element to incorporating personalized patches and embroidery, customize every aspect to showcase your personality and dedication."
    },
    {
      "type": "text",
      "id": "point_one",
      "label": "Point one",
      "default": "Change color of every component including stitching."
    },
    {
      "type": "text",
      "id": "point_two",
      "label": "Point two",
      "default": "Add up to 8 logos and art. Add text to your belt"
    },
    {
      "type": "text",
      "id": "point_three",
      "label": "Point three",
      "default": "Any sizes for the kimono, belt, and pants, ensuring a perfect fit."
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "START DESIGNING"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "SEE THE PROCESS"
    }
  ],
  "presets": [
    {
      "name": "DSPLN womens gi feature"
    }
  ]
}
{% endschema %}
