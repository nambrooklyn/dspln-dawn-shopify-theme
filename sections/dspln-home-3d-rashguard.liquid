{{ 'dspln-home-3d-rashguard.css' | asset_url | stylesheet_tag }}
<script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>

<section class="dspln-home-3d-rashguard" aria-label="Design your rashguard in 3D">
  <div class="dspln-home-3d-rashguard__inner">
    <div class="dspln-home-3d-rashguard__viewer">
      <model-viewer
        camera-controls
        touch-action="pan-y"
        disable-zoom
        src="{{ section.settings.model_url }}"
        alt="A 3D model of a custom rashguard"
        auto-rotate
        interaction-prompt="none"
      ></model-viewer>
    </div>

    <div class="dspln-home-3d-rashguard__copy">
      <p class="dspln-home-3d-rashguard__eyebrow">{{ section.settings.eyebrow }}</p>
      <h2 class="dspln-home-3d-rashguard__heading">{{ section.settings.heading }}</h2>
      <p class="dspln-home-3d-rashguard__text">{{ section.settings.text }}</p>

      <div class="dspln-home-3d-rashguard__actions">
        <a href="{{ section.settings.primary_link }}" class="dspln-home-3d-rashguard__button dspln-home-3d-rashguard__button--primary">
          {{ section.settings.primary_label }}
        </a>
        <a href="{{ section.settings.secondary_link }}" class="dspln-home-3d-rashguard__button dspln-home-3d-rashguard__button--secondary">
          {{ section.settings.secondary_label }}
        </a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "DSPLN 3D rashguard",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "CLICK AND MOVE THE 3D RASHGUARD"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "DESIGN YOUR RASHGUARD IN 3D"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Design your rashguard exactly how you envision it, with dynamic customization options that let you express your creativity effortlessly."
    },
    {
      "type": "url",
      "id": "primary_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "primary_label",
      "label": "Primary button label",
      "default": "START DESIGNING"
    },
    {
      "type": "url",
      "id": "secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "text",
      "id": "secondary_label",
      "label": "Secondary button label",
      "default": "HOW IT'S DONE"
    },
    {
      "type": "text",
      "id": "model_url",
      "label": "3D model URL",
      "default": "https://cdn.shopify.com/3d/models/31ac35ab2ac5ad35/Whiterashguard.glb"
    }
  ],
  "presets": [
    {
      "name": "DSPLN 3D rashguard"
    }
  ]
}
{% endschema %}
