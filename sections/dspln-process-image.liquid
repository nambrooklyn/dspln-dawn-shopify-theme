{{ 'dspln-process-image.css' | asset_url | stylesheet_tag }}

<section class="dspln-process-image" aria-label="{{ section.settings.accessibility_label | escape }}">
  <picture class="dspln-process-image__picture">
    {% if section.settings.mobile_image != blank %}
      <source media="(max-width: 749px)" srcset="{{ section.settings.mobile_image | image_url: width: 900 }}">
    {% else %}
      <source media="(max-width: 749px)" srcset="{{ 'dspln-process-mobile.webp' | asset_url }}">
    {% endif %}

    {% if section.settings.desktop_image != blank %}
      <img
        class="dspln-process-image__image"
        src="{{ section.settings.desktop_image | image_url: width: 1800 }}"
        alt="{{ section.settings.image_alt | escape }}"
        width="{{ section.settings.desktop_image.width }}"
        height="{{ section.settings.desktop_image.height }}"
        loading="lazy"
      >
    {% else %}
      <img
        class="dspln-process-image__image"
        src="{{ 'dspln-process-desktop.webp' | asset_url }}"
        alt="{{ section.settings.image_alt | escape }}"
        width="1600"
        height="720"
        loading="lazy"
      >
    {% endif %}
  </picture>
</section>

{% schema %}
{
  "name": "DSPLN process image",
  "settings": [
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "DSPLN custom gi process"
    },
    {
      "type": "text",
      "id": "accessibility_label",
      "label": "Section accessibility label",
      "default": "DSPLN process image"
    }
  ],
  "presets": [
    {
      "name": "DSPLN process image"
    }
  ]
}
{% endschema %}
